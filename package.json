{
  "name": "bjelectronics-production",
  "private": true,
  "workspaces": [
    "store",
    "admin",
    "api"
  ],
  "scripts": {
    "build": "npm run build:store",
    "start": "npm run start:store",
    "build:store": "npm install --prefix store && npm run build --prefix store",
    "start:store": "npm run start --prefix store",
    "build:admin": "npm install --prefix admin && npm run build --prefix admin",
    "start:admin": "npm run start --prefix admin",
    "build:api": "npm install --prefix api && node -c api/server.js",
    "start:api": "npm start --prefix api"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {}
}
